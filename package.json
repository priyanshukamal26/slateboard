{
  "name": "slateboard",
  "version": "0.2.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "test": "jest --testPathPattern=tests/ --forceExit",
    "build:ts": "npx tsc",
    "lint": "npx eslint server/**/*.js client/js/*.js",
    "format": "npx prettier --write \"server/**/*.js\" \"client/js/*.js\"",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate"
  },
  "engines": {
    "node": ">=18.x"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cookie-session": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "mongoose": "^8.7.1",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
